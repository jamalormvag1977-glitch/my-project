generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model FileMetadata {
  id              String   @id @default(cuid())
  fileName        String
  fileChecksum    String
  fileSize        Int
  fileLastModified DateTime
  lastSyncAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PPMProject {
  id                 Int      @id
  typeBudget         String
  natureBudget       String
  numAO              String?
  entite             String
  objet              String
  cp                 Float    @default(0)
  ce                 Float    @default(0)
  estimationAdmin    Float?
  dateOuverture      String?
  situationAvancement String
  dateJugement       String?
  attributaire       String?
  montantExtrait     Float?
  numMarche          String?
  montantEngagement  Float?
  engagementCP       Float?
  engagementCE       Float?
  dateEngagement     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([entite])
  @@index([situationAvancement])
  @@index([natureBudget])
  @@index([typeBudget])
}
